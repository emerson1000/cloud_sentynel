{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL":      { "value": "@supabase-url" },
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": { "value": "@supabase-anon-key" },
    "NEXT_PUBLIC_API_URL":           { "value": "@api-url" }
  }
}
