# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https:xxxx.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of your deployed FastAPI (Azure Functions or Container Apps)
# For local development: http://localhost:8000
NEXT_PUBLIC_API_URL=https://cloudsentinel-api.azurecontainerapps.io

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.cloudsentinel.io
